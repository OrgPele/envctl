#!/usr/bin/env python3

from __future__ import annotations

import os
from pathlib import Path
import sys


ROOT_DIR = Path(__file__).resolve().parents[1]
PYTHON_ROOT = ROOT_DIR / "python"
ORIGINAL_WRAPPER_ARGV0_ENVVAR = "ENVCTL_WRAPPER_ORIGINAL_ARGV0"
WRAPPER_REEXEC_ENVVAR = "ENVCTL_WRAPPER_PYTHON_REEXEC"


def _supported_runtime() -> bool:
    major, minor = sys.version_info[:2]
    return major == 3 and 12 <= minor <= 14


def _candidate_bins() -> list[str]:
    repo_venv = ROOT_DIR / ".venv" / "bin" / "python"
    candidates: list[str] = []
    if repo_venv.is_file():
        candidates.append(str(repo_venv))
    candidates.extend(["python3.14", "python3.13", "python3.12"])
    return candidates


def _preserve_original_wrapper_argv0() -> str:
    original = sys.argv[0]
    if os.environ.get(WRAPPER_REEXEC_ENVVAR) == "1":
        preserved = os.environ.get(ORIGINAL_WRAPPER_ARGV0_ENVVAR)
        if preserved:
            original = preserved
    else:
        os.environ[ORIGINAL_WRAPPER_ARGV0_ENVVAR] = original
    os.environ.pop(WRAPPER_REEXEC_ENVVAR, None)
    return original


def _reexec_supported_python(original_argv0: str) -> None:
    if _supported_runtime():
        return
    os.environ[ORIGINAL_WRAPPER_ARGV0_ENVVAR] = original_argv0
    os.environ[WRAPPER_REEXEC_ENVVAR] = "1"
    for candidate in _candidate_bins():
        try:
            os.execvp(candidate, [candidate, str(Path(__file__).resolve()), *sys.argv[1:]])
        except OSError:
            continue
    raise SystemExit("Python 3.12-3.14 is required for envctl.")


def _ensure_repo_python_root() -> None:
    python_root_str = str(PYTHON_ROOT.resolve())
    sys.path[:] = [entry for entry in sys.path if entry != python_root_str]
    sys.path.insert(0, python_root_str)
    for name in list(sys.modules):
        if name != "envctl_engine" and not name.startswith("envctl_engine."):
            continue
        module = sys.modules.get(name)
        module_file = getattr(module, "__file__", None)
        if not module_file:
            continue
        try:
            module_path = Path(module_file).resolve()
        except OSError:
            continue
        if PYTHON_ROOT.resolve() not in module_path.parents:
            del sys.modules[name]


def main() -> int:
    original_argv0 = _preserve_original_wrapper_argv0()
    _reexec_supported_python(original_argv0)
    _ensure_repo_python_root()
    from envctl_engine.runtime.launcher_support import select_envctl_reexec_target

    alternate = select_envctl_reexec_target(Path(__file__).resolve(), original_argv0, env=os.environ)
    if alternate is not None:
        print(
            (
                f"envctl repo wrapper at {Path(__file__).resolve()} is shadowing installed envctl at {alternate}; "
                "re-executing installed envctl. Set ENVCTL_USE_REPO_WRAPPER=1 to force the repo wrapper."
            ),
            file=sys.stderr,
        )
        os.execv(str(alternate), [str(alternate), *sys.argv[1:]])
    os.environ.setdefault("ENVCTL_ROOT_DIR", str(ROOT_DIR))
    from envctl_engine.runtime.launcher_cli import main as launcher_main

    return int(launcher_main())


if __name__ == "__main__":
    raise SystemExit(main())
