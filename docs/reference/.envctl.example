# .envctl.example
#
# envctl orchestration config (separate from your application `.env` files).
# Copy this to `.envctl` at the project root and override what you need.

# ==========================================
# Core
# ==========================================

# Default startup mode when no mode flag is passed.
# Allowed: main | trees
ENVCTL_DEFAULT_MODE=main

# Default dependency stack for trees mode when no dependency-scope flag is passed.
# Allowed: shared | isolated
# ENVCTL_DEFAULT_TREE_DEPENDENCY_SCOPE=shared

# Planning root directory for --plan / --sequential-plan / --planning-prs.
ENVCTL_PLANNING_DIR=todo/plans

# Worktree code intelligence bootstrap. Serena config is copied by default when present.
# Graph tooling is opt-in: unset/false skips .cgcignore, .codegraphcontext, and cgc calls.
# ENVCTL_WORKTREE_CODE_INTELLIGENCE=auto
# ENVCTL_WORKTREE_CGC_INDEX=false
# ENVCTL_WORKTREE_CGC_INDEX=auto
# ENVCTL_WORKTREE_CGC_INDEX=true
# ENVCTL_WORKTREE_SERENA_PROJECT_TEMPLATE={project}-{worktree}
# ENVCTL_WORKTREE_CGC_CONTEXT_TEMPLATE={project}-{worktree}
# ENVCTL_WORKTREE_CGC_SOURCE_CONTEXT=Envctl
# ENVCTL_WORKTREE_CGC_DATABASE=kuzudb

# Host/IP injected into browser-facing frontend env URLs such as VITE_BACKEND_URL and VITE_API_URL.
# Dashboard visual URLs default to this same host unless ENVCTL_UI_VISUAL_HOST is set explicitly.
# Ports remain dynamic per project/worktree; service binding and probes are unchanged.
ENVCTL_PUBLIC_HOST=localhost

# Optional dashboard-only override for visual service URLs.
# Leave blank/unset to reuse ENVCTL_PUBLIC_HOST.
ENVCTL_UI_VISUAL_HOST=localhost

# ==========================================
# Service discovery and ports
# ==========================================

# Repo-relative directories used for backend/frontend auto-discovery.
BACKEND_DIR=backend
FRONTEND_DIR=frontend

# Base ports used for the main project slot.
BACKEND_PORT_BASE=8000
FRONTEND_PORT_BASE=9000

# Optional additional application services. These are repo-owned long-running
# processes such as workers, schedulers, sidecars, or gateways. They render in
# dashboard rows and can be targeted as `voice-runtime`, `service:voice-runtime`,
# `Voice Runtime`, or `Main Voice Runtime` for stop/restart/log/test commands.
# ENVCTL_ADDITIONAL_SERVICES=voice-runtime,worker
# ENVCTL_SERVICE_VOICE_RUNTIME_ENABLE=true
# ENVCTL_SERVICE_VOICE_RUNTIME_DIR=voice-runtime
# ENVCTL_SERVICE_VOICE_RUNTIME_PORT_BASE=8010
# ENVCTL_SERVICE_VOICE_RUNTIME_START_CMD=scripts/envctl/start-voice-runtime.sh {port}
# ENVCTL_SERVICE_VOICE_RUNTIME_EXPECT_LISTENER=true
# ENVCTL_SERVICE_VOICE_RUNTIME_HEALTH_URL=http://${ENVCTL_SOURCE_SERVICE_VOICE_RUNTIME_HOST}:${ENVCTL_SOURCE_SERVICE_VOICE_RUNTIME_PORT}/readyz
# ENVCTL_SERVICE_VOICE_RUNTIME_PUBLIC_URL=http://${ENVCTL_SOURCE_SERVICE_VOICE_RUNTIME_HOST}:${ENVCTL_SOURCE_SERVICE_VOICE_RUNTIME_PORT}
# ENVCTL_SERVICE_VOICE_RUNTIME_DEPENDS_ON=backend
# ENVCTL_SERVICE_VOICE_RUNTIME_CRITICAL=true
# ENVCTL_SERVICE_VOICE_RUNTIME_TEST_CMD=scripts/envctl/test-voice-runtime.sh
# ENVCTL_SERVICE_WORKER_ENABLE=true
# ENVCTL_SERVICE_WORKER_DIR=backend
# ENVCTL_SERVICE_WORKER_START_CMD=python -m app.worker
# ENVCTL_SERVICE_WORKER_EXPECT_LISTENER=false
# ENVCTL_SERVICE_WORKER_DEPENDS_ON=backend
# ENVCTL_SERVICE_WORKER_CRITICAL=false
# ENVCTL_SERVICE_WORKER_TEST_CMD=python -m pytest tests/test_worker.py
# The interactive config wizard can edit these keys and preserves service launch-env sections;
# configured services expose canonical project/service_slug/public_url/health_url
# fields through show-state --json, health --json, runtime maps, and dashboard rows.

# Spacing between project slots in trees mode.
PORT_SPACING=20

# ==========================================
# Dependency base ports
# ==========================================

DB_PORT=5432
REDIS_PORT=6379
N8N_PORT_BASE=5678
# Public Supabase API/Kong port. ENVCTL_SOURCE_SUPABASE_URL uses this port; DB URLs use DB_PORT.
SUPABASE_PUBLIC_PORT=54321

# Optional managed Supabase Auth users for local/E2E login.
# ENVCTL_SUPABASE_AUTH_USERS=e2e
# ENVCTL_SUPABASE_USER_E2E_EMAIL=e2e@example.test
# ENVCTL_SUPABASE_USER_E2E_PASSWORD=change-me-local-only
# ENVCTL_SUPABASE_USER_E2E_USER_METADATA_JSON={"company_name":"E2E Co"}
# ENVCTL_SUPABASE_USER_E2E_APP_METADATA_JSON={"role":"tester"}
# ENVCTL_SUPABASE_AUTH_USERS_STRICT=true

# ==========================================
# Main mode startup profile
# ==========================================

# Master switch for whether main mode auto-starts anything at all.
MAIN_STARTUP_ENABLE=true
MAIN_BACKEND_ENABLE=true
MAIN_BACKEND_EXPECT_LISTENER=true
MAIN_FRONTEND_ENABLE=true
MAIN_POSTGRES_ENABLE=false
MAIN_REDIS_ENABLE=false
MAIN_SUPABASE_ENABLE=false
MAIN_N8N_ENABLE=false

# ==========================================
# Trees mode startup profile
# ==========================================

# Master switch for whether trees mode auto-starts anything at all.
TREES_STARTUP_ENABLE=true
TREES_BACKEND_ENABLE=true
TREES_BACKEND_EXPECT_LISTENER=true
TREES_FRONTEND_ENABLE=true
TREES_POSTGRES_ENABLE=false
TREES_REDIS_ENABLE=false
TREES_SUPABASE_ENABLE=false
TREES_N8N_ENABLE=false

# ==========================================
# Plan-agent prompt follow-ups
# ==========================================

# Codex TUI queued workflow count for plan-agent launches, including OMX-managed Codex sessions.
# OpenCode ignores this setting.
# 0 submits one implementation prompt plus enabled follow-ups.
# 1 queues implement_task -> finalize_task plus enabled follow-ups.
# 2+ adds continue/implement cycles before finalization.
ENVCTL_PLAN_AGENT_CODEX_CYCLES=2

# Submit a concise Codex `/goal` session frame before the implementation prompt.
# Applies to Codex cmux, tmux, and OMX-managed tmux launches; OpenCode ignores it.
ENVCTL_PLAN_AGENT_CODEX_GOAL_ENABLE=true

# Workspace-backed plan-agent transport. "cmux" opens interactive terminal surfaces.
# "superset" uses Superset's public high-level workspace/agent CLI and sends only
# the initial rendered Codex implementation prompt.
ENVCTL_PLAN_AGENT_SURFACE_TRANSPORT=cmux
ENVCTL_PLAN_AGENT_SUPERSET_PROJECT=
ENVCTL_PLAN_AGENT_SUPERSET_WORKSPACE=
ENVCTL_PLAN_AGENT_SUPERSET_HOST=
ENVCTL_PLAN_AGENT_SUPERSET_LOCAL=true
ENVCTL_PLAN_AGENT_SUPERSET_OPEN=true

# Queue an extra Codex/OMX prompt after implementation/finalization to run
# browser-based E2E validation with $browser against the full envctl stack.
# Set to true to queue the optional browser E2E follow-up after implementation/finalization.
ENVCTL_PLAN_AGENT_BROWSER_E2E_ENABLE=false

# For Codex full-stack frontend+backend app launches, automatically queue the
# PR-URL browser E2E follow-up after envctl ship. The follow-up validates the
# deployed PR URL instead of localhost or envctl runtime URLs.
ENVCTL_PLAN_AGENT_FULLSTACK_PR_URL_E2E_ENABLE=false

# Queue an extra Codex/OMX prompt after implementation and optional browser-E2E prompts
# to inspect unresolved PR review comments and address all actionable feedback.
# Set to false to skip this follow-up for repos where PR comment handling is manual.
ENVCTL_PLAN_AGENT_PR_REVIEW_COMMENTS_ENABLE=true

# ==========================================
# Ship / PR automation
# ==========================================

# Programmatically add a GitHub label to PRs during `envctl ship`.
# Disabled by default; set true only for repos that want this automation.
ENVCTL_SHIP_PR_LABEL_ENABLE=false
# Optional label name. envctl creates the repo label when missing.
ENVCTL_SHIP_PR_LABEL=deploy-app

# ==========================================
# Service launch env templates
# ==========================================

# Managed dependency startup parallelism can be configured here too.
# Linux defaults to parallel startup. macOS defaults to sequential startup
# to avoid Docker Desktop port-publish stalls. Override either default with:
# ENVCTL_REQUIREMENTS_PARALLEL=true
# ENVCTL_REQUIREMENTS_PARALLEL_MAX=4

# External dependency mode can be configured in this same .envctl file.
# Default mode is managed: envctl starts enabled dependencies and projects localhost values.
# Main mode auto-uses an external dependency when that dependency's own env vars exist
# in shell env, .envctl, project root .env, backend .env, or frontend .env,
# unless that dependency is already configured as managed/enabled.
# Trees mode defaults to managed/internal dependencies unless external mode is explicit.
# For one-off main runs that should ignore external env auto-detection, use
# `envctl --main --managed-deps` or the alias `envctl --main --no-external-deps`.
# To use externally running services, enable one or more external dependencies:
# ENVCTL_EXTERNAL_DEPENDENCIES=supabase,redis,postgres,n8n
# Or use one dependency at a time:
# ENVCTL_DEPENDENCY_SUPABASE_MODE=external
# ENVCTL_DEPENDENCY_REDIS_MODE=external
# ENVCTL_DEPENDENCY_POSTGRES_MODE=external
# ENVCTL_DEPENDENCY_N8N_MODE=external
# External Supabase requires SUPABASE_URL or SUPABASE_PUBLIC_URL plus SUPABASE_ANON_KEY
# or the frontend-safe VITE_SUPABASE_ANON_KEY alias.
# External dependencies are actively probed at startup. Set
# ENVCTL_EXTERNAL_DEPENDENCY_PROBE=false only when the dependency is reachable
# from launched services but intentionally unreachable from the envctl host.
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=<external anon key>
# SUPABASE_SERVICE_ROLE_KEY=<external service-role key; backend only>
# SUPABASE_JWT_SECRET=<external JWT secret; backend only>
# SUPABASE_JWKS_URL=${SUPABASE_URL}/auth/v1/.well-known/jwks.json
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@localhost:5432/postgres
# REDIS_URL=redis://localhost:6379/0
# N8N_URL=http://localhost:5678
# Local managed Supabase defaults are local-only secrets:
# SUPABASE_DB_PASSWORD=supabase-db-password
# SUPABASE_JWT_SECRET=supabase-local-jwt-secret
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxvY2FsaG9zdCIsInJvbGUiOiJhbm9uIiwiaWF0IjoxNjQxNzY5MjAwLCJleHAiOjE5NTczNDUyMDB9.Oi-sX984UQkmFwiDY2_7Qy4Qb33dH9e45FMDT9NgqE0
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxvY2FsaG9zdCIsInJvbGUiOiJzZXJ2aWNlX3JvbGUiLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTk1NzM0NTIwMH0.Hx36U1Vm86vGaBd-my6npKZLHfpSFnmHrZ0v43eXVnA

# Launch env templates for services started by envctl.
# Backend goes only to the backend process. Frontend goes only to the frontend process.
# `${ENVCTL_SOURCE_*}` values come from envctl-managed dependencies.
# >>> envctl backend launch env >>>
DATABASE_URL=${ENVCTL_SOURCE_DATABASE_URL}  # generic DB URL; e.g. postgresql://user:pass@host:5432/dbname
REDIS_URL=${ENVCTL_SOURCE_REDIS_URL}  # Redis URL; e.g. redis://host:6379/0
N8N_URL=${ENVCTL_SOURCE_N8N_URL}  # n8n base URL; e.g. http://localhost:5678
SUPABASE_URL=${ENVCTL_SOURCE_SUPABASE_URL}  # Supabase base URL; e.g. http://localhost:54321
SUPABASE_JWKS_URL=${ENVCTL_SOURCE_SUPABASE_JWKS_URL}  # backend-only JWT verification JWKS URL
SUPABASE_JWT_SECRET=${ENVCTL_SOURCE_SUPABASE_JWT_SECRET}  # backend-only local JWT secret
SUPABASE_SERVICE_ROLE_KEY=${ENVCTL_SOURCE_SUPABASE_SERVICE_ROLE_KEY}  # backend-only Admin API key
SQLALCHEMY_DATABASE_URL=${ENVCTL_SOURCE_SQLALCHEMY_DATABASE_URL}  # SQLAlchemy sync URL; e.g. postgresql+psycopg://user:pass@host:5432/dbname
ASYNC_DATABASE_URL=${ENVCTL_SOURCE_ASYNC_DATABASE_URL}  # SQLAlchemy async URL; e.g. postgresql+asyncpg://user:pass@host:5432/dbname
# APP_DATABASE_URL=${ENVCTL_SOURCE_DATABASE_URL}  # extra backend alias example
# <<< envctl backend launch env <<<

# >>> envctl frontend launch env >>>
# VITE_SUPABASE_URL=${ENVCTL_SOURCE_SUPABASE_URL}  # frontend-only Supabase URL
# VITE_SUPABASE_ANON_KEY=${ENVCTL_SOURCE_SUPABASE_ANON_KEY}  # frontend-safe Supabase anon key
# Do not map ENVCTL_SOURCE_SUPABASE_SERVICE_ROLE_KEY in frontend sections.
# <<< envctl frontend launch env <<<

# Additional service launch env sections use the configured service slug.
# >>> envctl service voice-runtime launch env >>>
# VOICE_RUNTIME_PUBLIC_URL=${ENVCTL_SOURCE_SERVICE_VOICE_RUNTIME_PUBLIC_URL}
# <<< envctl service voice-runtime launch env <<<

# Notes:
# - `.envctl` is the canonical repo-local config file.
# - The interactive `envctl config` wizard edits and preserves canonical managed keys, including additional app services.
# - All launch env template sections are user-owned and preserved as-is.
# - If a mode has `*_STARTUP_ENABLE=false`, `start`, `resume`, and `restart`
#   for that mode are blocked until you re-enable startup.
